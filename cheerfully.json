{
    "allosaurus": [{
        "src": "./example/vo/en/",
        "output": "./example/lipsync/en/",
        "options": {
            "rhubarb": true,
            "transcribe": true,
            "transition": true,
            "k": 3,
            "e": 0.8
        }
    }],
    "rhubarb": [{
        "script": "./example/script.json",
        "src": "./example/vo/en/",
        "output": "./example/lipsync/en/"
    }, {
        "options": {
            "exportFormat": "tsv",
            "output": "files"
        },
        "script": "./example/script.json",
        "src": "./example/vo/en/",
        "output": "./example/lipsync/en/"
    }, {
        "options": {
            "exportFormat": "xml",
            "output": "files"
        },
        "script": "./example/script.json",
        "src": "./example/vo/en/",
        "output": "./example/lipsync/en/"
    }, {
        "options": {
            "exportFormat": "dat",
            "output": "files"
        },
        "script": "./example/script.json",
        "src": "./example/vo/en/",
        "output": "./example/lipsync/en/"
    }, {
        "options": {
            "exportFormat": "mp3",
            "output": "files"
        },
        "script": "./example/script.json",
        "src": "./example/vo/en/",
        "output": "./example/vo/en/"
    }],
    "polly": [{
        "script": "./example/script.json",
        "output": "./example/vo/en/",
        "language": "en-US",
        "updateAllMetaData": true,
        "voice": "Ivy"
    }],
    "elevenlabs": [{
        "script": "./example/script.json",
        "output": "./example/vo/en/",
        "voice": {
            "default": "jBpfuIE2acCO8z3wKNLl",
            "Brooke": "zrHiDhphv9ZnVXBqCLjz",
            "Zach": "bVMeCyTHy58xNoL34h3p"
        }
    }],
    "ffmpeg": [{
        "options": {"ac": 1},
        "src": "./example/vo/en/",
        "output": "./example/vo/en/"
    }],
    "packfully": [{
        "format": "texturepacker",
        "src": "./example/sprites/",
        "output": "./example/atlases/",
        "options": {
            "maxWidth": 512,
            "maxHeight": 512,
            "pot": true,
            "smart": true,
            "padding": 1,
            "extrude": 1,
            "border": 1,
            "trim": true,
            "allowRotation": false,
            "prefix": "packed"
        }
    }, {
        "exports": ["texturepacker", "createjs"],
        "src": "./example/sprites/",
        "output": "./example/atlases/",
        "options": {
            "maxWidth": 512,
            "maxHeight": 512,
            "pot": true,
            "smart": true,
            "padding": 2,
            "extrude": 1,
            "prefix": "multi"
        }
    }],
    "rasterize": [{
        "src": "./example/images/",
        "output": "./example/images/"
    }, {
        "exportFormat": "easeljs",
        "src": "./example/images/",
        "output": "./example/images/"
    }],
    "transcription": [{
        "format": "sami",
        "prependSpeaker": true,
        "script": "./example/script.json",
        "src": "./example/vo/en/",
        "output": "./example/captions/en/",
        "language": "en-US"
    }, {
        "format": "smi",
        "prependSpeaker": " - ",
        "script": "./example/script.json",
        "src": "./example/vo/en/",
        "output": "./example/captions/en/",
        "language": "en-US"
    }, {
        "format": "vtt",
        "script": "./example/script.json",
        "src": "./example/vo/en/",
        "output": "./example/captions/en/",
        "language": "en-US"
    }, {
        "format": "srt",
        "prependSpeaker": "[]",
        "script": "./example/script.json",
        "src": "./example/vo/en/",
        "lines": 2,
        "output": "./example/captions/en/",
        "language": "en-US"
    }, {
        "script": "./example/script.json",
        "src": "./example/vo/en/",
        "output": "./example/captions/en/",
        "language": "en-US"
    }, {
        "format": "lrc",
        "prependSpeaker": ["(", ")"],
        "script": "./example/script.json",
        "src": "./example/vo/en/",
        "output": "./example/vo/en/",
        "language": "en-US"
    }, {
        "format": "mp3",
        "script": "./example/script.json",
        "src": "./example/vo/en/",
        "output": "./example/vo/en/",
        "language": "en-US"
    }]
}