{
    "name": "@makefully/dutifully",
    "version": "1.11.0",
    "description": "Client tools for Cheerfully service.",
    "main": "./src/index.js",
    "bin": {
        "cheer": "./cheer.js",
        "say": "./say.js"
    },
    "files": [
        "cheer.js",
        "say.js",
        "src",
        "CHANGELOG.md",
        "LICENSE",
        "README.md"
    ],
    "scripts": {
        "test-allosaurus": "node ./cheer.js -service allosaurus",
        "test-elevenlabs": "node ./cheer.js -service elevenlabs",
        "test-ffmpeg": "node ./cheer.js -service ffmpeg",
        "test-polly": "node ./cheer.js -service polly",
        "test-rasterize": "node ./cheer.js -service rasterize",
        "test-rhubarb": "node ./cheer.js -service rhubarb",
        "test-transcription": "node ./cheer.js -service transcription",
        "say": "node ./say.js"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Makefully-Studios/dutifully.git"
    },
    "bugs": {
        "url": "https://github.com/Makefully-Studios/dutifully/issues"
    },
    "homepage": "https://github.com/Makefully-Studios/dutifully#readme",
    "keywords": [
        "cheerfully",
        "dutifully",
        "tts",
        "elevenlabs",
        "polly",
        "lipsync",
        "transcription",
        "captions"
    ],
    "author": "Derek Detweiler <derek@makefullystudios.com>",
    "contributors": [
        "Derek Detweiler <derek@makefullystudios.com>"
    ],
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    },
    "engines": {
        "node": ">=18"
    },
    "dependencies": {
        "archiver": "^4.0.1",
        "node-id3": "^0.2.6",
        "node-web-audio-api": "^2.0.0",
        "unzip-stream": "^0.3.0"
    }
}
